# Polymarket US Trading Account API Credentials
# Get these from https://polymarket.us/developer
POLYMARKET_KEY_ID=your-key-id-here-uuid
POLYMARKET_SECRET_KEY=your-secret-key-here-base64

# Trading Configuration
MAX_POSITION_SIZE_PER_MARKET=0.25  # Maximum 25% of balance per market
BASE_RISK_PERCENT=0.025
STARTING_BANKROLL=100  # Test mode only - live mode uses actual API balance
MAX_PRICE_TOLERANCE=0.011
LIQUIDATION_PRICE=0.99
ENABLE_AUTO_LIQUIDATION=false  # Automatically place limit sell orders for all positions
ALLOW_BUY_SHORT=true  # Enable buying NO-side tokens (index 1) to copy trades exactly
MIN_BUY_PRICE=0.00
MAX_BUY_PRICE=0.951
SPORTS_ONLY=true  # Filter for sports markets only (NBA, NFL, NHL, MLB, etc)

# Trader Selection Criteria
MIN_WIN_RATE=75
MIN_TRADES_PER_DAY=5
MAX_TRADES_PER_DAY=75
TOP_N_USERS=25
CANDIDATE_LIMIT=500
# Required trader tags (comma-separated, leave empty for no tag filtering)
# Examples: "Sports PnL > $100k", "1k+ Positions", "Overall PnL > $1m"
REQUIRED_TRADER_TAGS=Sports PnL > $100k

# Polling Configuration
SCAN_INTERVAL_SECONDS=30  # Time between personal account refresh cycles
DAILY_POLL_SECONDS=86400  # Refresh monitored trader set every 24h
TRADE_POLL_SECONDS=1  # Delay between trader trade pulls
TRADE_POLL_CONCURRENCY=10  # Number of tracked accounts polled concurrently
TRADE_PAGE_SIZE=200
TRADE_MAX_PAGES_PER_POLL=1
US_UNTRADABLE_CACHE_SECONDS=1800  # Cache US-untradable slugs for 30 minutes

# Size Normalization (from existing polymarket_tracker)
TAIL_MIN_MULTIPLIER=0.9
TAIL_MAX_MULTIPLIER=1.6
TAIL_MULTIPLIER_CURVE_POWER=1.35
TAIL_LOW_SIZE_THRESHOLD_RATIO=0.12
TAIL_LOW_SIZE_HAIRCUT_POWER=0.5
TAIL_LOW_SIZE_HAIRCUT_MIN_FACTOR=0.35
TAIL_MAX_TRADE_NOTIONAL_PCT=0.08

# Test Mode Configuration
TEST_EXCEL_WORKBOOK=test_performance.xlsx

# Live Mode Configuration
LIVE_EXCEL_WORKBOOK=live_performance.xlsx

# Logging
LOG_LEVEL=INFO
LOG_FILE=copytrade.log
